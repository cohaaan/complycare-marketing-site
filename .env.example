# Google Apps Script Web App URL for form submissions
# Deploy your script as Web app (Anyone) and paste the URL here
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Stripe embedded buy button (optional - enables in-page checkout at /payments)
# Get from: Stripe Dashboard → Developers → API keys (publishable) and Payment Links → [your link] → Buy button
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
VITE_STRIPE_BUY_BUTTON_ID=xxx
